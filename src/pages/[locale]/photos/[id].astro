---
import Layout from '@/layouts/Layout.astro';
import PageHead from '@/components/PageHead.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PhotoProtection from '@/components/PhotoProtection.astro'
import { getAllPhotos, getPhotosByLocale, getAlbumImages, hasPhotoTranslation, parseAuthors, getBaseSlug } from '@/lib/data-utils'
import { Image } from "astro:assets";
import { GalleryViewer } from "@/components/react/GalleryViewer";
import { AuthorBadge } from "@/components/react/AuthorBadge";
import { Badge } from "@/components/ui/badge";
import { Separator } from "@/components/ui/separator";

export async function getStaticPaths() {
  const esAlbums = await getPhotosByLocale('es')
  const enAlbums = await getAllPhotos()

  const esCoveredSlugs = new Set(esAlbums.map((a) => getBaseSlug(a.id, 'es')))

  const esPaths = esAlbums.map((album) => ({
    params: { locale: 'es', id: getBaseSlug(album.id, 'es') },
    props: { album },
  }))

  // EN albums without an ES translation fall back to English content
  const fallbackPaths = enAlbums
    .filter((album) => !esCoveredSlugs.has(album.id))
    .map((album) => ({
      params: { locale: 'es', id: album.id },
      props: { album },
    }))

  return [...esPaths, ...fallbackPaths]
}

const { album } = Astro.props;
const { locale } = Astro.params;
const albumImages = await getAlbumImages(album.id);
const viewerImages = albumImages.map((img) => ({
    src: typeof img.src === 'object' ? img.src.src : img.src,
    fileName: img.fileName,
    width: typeof img.src === 'object' ? img.src.width : undefined,
    height: typeof img.src === 'object' ? img.src.height : undefined,
}));
const authors = await parseAuthors(album.data.authors ?? []);
const coverSrc = typeof album.data.image === 'object' ? (album.data.image as { src: string }).src : String(album.data.image);
---

<Layout class="max-w-3xl">
  <PageHead
    slot="head"
    title={`${album.data.name} - Gallery`}
    description={album.data.description || `Gallery for ${album.data.name}`}
  />
  <meta slot="head" name="post-locale" content={locale} />
  <meta slot="head" name="post-slug" content={Astro.params.id} />
  <meta slot="head" name="post-section" content="photos" />
  <meta slot="head" name="post-has-en" content="true" />

  <Breadcrumbs
    items={[
      { label: 'Photos', href: `/${locale}/photos`, icon: 'lucide:camera', i18nKey: 'gallery.breadcrumb' },
      { label: album.data.name, icon: 'lucide:image' }
    ]}
  />

  <article class="mb-24">

    {/* --- SECCIÓN HERO: Imagen Principal + Info --- */}
    <div class="flex flex-col md:flex-row gap-6 md:gap-8 mb-8 items-start">

        {/* Imagen de Portada (Izquierda) */}
        <div class="w-full md:w-3/5 shrink-0">
            <div class="rounded-xl overflow-hidden border border-border/50 bg-muted shadow-sm aspect-[4/3] relative">
                <Image
                    src={album.data.image}
                    alt={album.data.name}
                    class="w-full h-full object-cover"
                    loading="eager"
                    width={800}
                />
            </div>
        </div>

        {/* Información (Derecha) */}
        <div class="flex flex-col w-full md:w-2/5 space-y-4">

            {/* Título y Descripción */}
            <div class="space-y-2">
                <h1 class="text-2xl font-bold tracking-tight lg:text-3xl text-foreground">
                    {album.data.name}
                </h1>
                {album.data.title && (
                    <p class="text-lg font-medium text-muted-foreground leading-tight">
                        {album.data.title}
                    </p>
                )}
                {album.data.description && (
                    <p class="text-sm leading-relaxed text-foreground/80 pt-1">
                        {album.data.description}
                    </p>
                )}
            </div>

            <Separator className="my-1" />

            {/* Grid de Metadatos */}
            <div class="grid grid-cols-2 gap-y-4 gap-x-2">

                {/* Autores */}
                <div class="col-span-2">
                    <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-1.5 block">
                        Created by
                    </span>
                    <div class="flex flex-wrap gap-2">
                        {authors.map((author) => (
                            <AuthorBadge client:load author={author} />
                        ))}
                    </div>
                </div>

                {/* Modelo / Cámara */}
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-1 block">
                        Model / Camera
                    </span>
                    <p class="text-sm font-medium text-foreground flex items-center gap-2">
                         {album.data.model || 'Unknown'}
                    </p>
                </div>

                {/* Fecha */}
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-1 block">
                        Date
                    </span>
                    <p class="text-sm font-medium text-foreground">
                        {album.data.date ? album.data.date.toLocaleDateString(undefined, { dateStyle: 'medium' }) : 'N/A'}
                    </p>
                </div>
            </div>

            {/* Tags */}
            {album.data.tags.length > 0 && (
                <div class="pt-1">
                    <div class="flex flex-wrap gap-1.5">
                        {album.data.tags.map(tag => (
                            <Badge variant="secondary" className="px-2 py-0 text-[10px] text-muted-foreground hover:text-foreground transition-colors cursor-default border-transparent bg-secondary/50">
                                #{tag}
                            </Badge>
                        ))}
                    </div>
                </div>
            )}
        </div>
    </div>

    {/* --- SECCIÓN GALERÍA (Masonry) --- */}
    {albumImages.length > 0 && (
        <section class="mt-16">
            <div class="flex items-center gap-4 mb-8">
                <h3 class="text-2xl font-bold tracking-tight">Gallery Assets</h3>
                <Separator className="flex-1" />
                {!album.data.protected && (
                  <span class="text-xs text-muted-foreground font-medium uppercase tracking-widest">
                      {albumImages.length} images
                  </span>
                )}
            </div>

            <PhotoProtection
              isProtected={!!album.data.protected}
              password={album.data.password}
              albumId={album.id}
              coverSrc={coverSrc}
              images={viewerImages}
              protectionMessage={album.data.protectionMessage}
            >
              <GalleryViewer client:load images={viewerImages} />
            </PhotoProtection>
        </section>
    )}
  </article>

</Layout>
