---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import Link from '@/components/Link.astro'
import { Icon } from 'astro-icon/components'

const pageUrl = new URL(Astro.url.pathname, Astro.site).href
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Free Online Tools",
  "description": "Collection of free online tools for system administrators, developers, and IT professionals. Password generator, subnet calculator, IP lookup, DNS lookup, Base64 encoder, JSON formatter, YAML validator, and Docker run to Compose converter.",
  "url": pageUrl,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Password Generator",
        "url": new URL("/tools/password-generator", Astro.site).href
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Subnet Calculator",
        "url": new URL("/tools/subnet-calculator", Astro.site).href
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "IP & DNS Lookup",
        "url": new URL("/tools/ip-dns-lookup", Astro.site).href
      },
      {
        "@type": "ListItem",
        "position": 4,
        "name": "Base64 Encoder & Decoder",
        "url": new URL("/tools/base64-encoder", Astro.site).href
      },
      {
        "@type": "ListItem",
        "position": 5,
        "name": "JSON Formatter & Validator",
        "url": new URL("/tools/json-formatter", Astro.site).href
      },
      {
        "@type": "ListItem",
        "position": 6,
        "name": "YAML Validator & Formatter",
        "url": new URL("/tools/yaml-validator", Astro.site).href
      },
      {
        "@type": "ListItem",
        "position": 7,
        "name": "Docker Run to Compose Converter",
        "url": new URL("/tools/docker-converter", Astro.site).href
      },
      {
        "@type": "ListItem",
        "position": 8,
        "name": "ASCII Converter",
        "url": new URL("/tools/ascii-converter", Astro.site).href
      }
    ]
  }
}
---

<Layout class="max-w-3xl">
  <PageHead 
    slot="head" 
    title="Free Online Tools - Password Generator, Subnet Calculator, IP Lookup"
    description="Free online tools for system administrators, developers, and IT professionals. Password generator, subnet calculator, IP lookup, DNS lookup, Base64 encoder, JSON formatter, YAML validator, and Docker run to Compose converter. All tools run in your browser."
  />
  
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <Breadcrumbs items={[{ label: 'Tools', icon: 'lucide:wrench' }]} />

  <article class="flex flex-col gap-y-6">
    <header class="space-y-2">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight" data-i18n="tools.heading">Tools</h1>
      <p class="text-muted-foreground" data-i18n="tools.desc">
        Free online tools for system administrators, developers, and IT professionals.
      </p>
    </header>

    <div class="space-y-1">
      <Link
        href="/tools/password-generator"
        class="group flex items-center gap-4 p-4 rounded-lg hover:bg-muted/50 transition-colors"
      >
        <Icon name="lucide:shield-check" class="size-5 text-primary shrink-0" />
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold group-hover:text-primary transition-colors" data-i18n="tools.password_gen">
            Password Generator
          </h2>
          <p class="text-sm text-muted-foreground" data-i18n="tools.password_desc">
            Generate secure passwords and check strength
          </p>
        </div>
        <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground group-hover:text-primary shrink-0" />
      </Link>

      <Link
        href="/tools/subnet-calculator"
        class="group flex items-center gap-4 p-4 rounded-lg hover:bg-muted/50 transition-colors"
      >
        <Icon name="lucide:network" class="size-5 text-primary shrink-0" />
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold group-hover:text-primary transition-colors" data-i18n="tools.subnet_calc">
            Subnet Calculator
          </h2>
          <p class="text-sm text-muted-foreground" data-i18n="tools.subnet_desc">
            Calculate subnet masks and network addresses
          </p>
        </div>
        <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground group-hover:text-primary shrink-0" />
      </Link>

      <Link
        href="/tools/ip-dns-lookup"
        class="group flex items-center gap-4 p-4 rounded-lg hover:bg-muted/50 transition-colors"
      >
        <Icon name="lucide:search" class="size-5 text-primary shrink-0" />
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold group-hover:text-primary transition-colors" data-i18n="tools.ip_dns">
            IP &amp; DNS Lookup
          </h2>
          <p class="text-sm text-muted-foreground" data-i18n="tools.ip_dns_desc">
            Lookup IP geolocation and DNS records
          </p>
        </div>
        <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground group-hover:text-primary shrink-0" />
      </Link>

      <Link
        href="/tools/base64-encoder"
        class="group flex items-center gap-4 p-4 rounded-lg hover:bg-muted/50 transition-colors"
      >
        <Icon name="lucide:code" class="size-5 text-primary shrink-0" />
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold group-hover:text-primary transition-colors" data-i18n="tools.base64">
            Base64 Encoder &amp; Decoder
          </h2>
          <p class="text-sm text-muted-foreground" data-i18n="tools.base64_desc">
            Encode and decode Base64 strings
          </p>
        </div>
        <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground group-hover:text-primary shrink-0" />
      </Link>

      <Link
        href="/tools/json-formatter"
        class="group flex items-center gap-4 p-4 rounded-lg hover:bg-muted/50 transition-colors"
      >
        <Icon name="lucide:code" class="size-5 text-primary shrink-0" />
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold group-hover:text-primary transition-colors" data-i18n="tools.json_fmt">
            JSON Formatter &amp; Validator
          </h2>
          <p class="text-sm text-muted-foreground" data-i18n="tools.json_desc">
            Format, validate, and minify JSON strings
          </p>
        </div>
        <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground group-hover:text-primary shrink-0" />
      </Link>

      <Link
        href="/tools/yaml-validator"
        class="group flex items-center gap-4 p-4 rounded-lg hover:bg-muted/50 transition-colors"
      >
        <Icon name="lucide:file-code" class="size-5 text-primary shrink-0" />
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold group-hover:text-primary transition-colors" data-i18n="tools.yaml_val">
            YAML Validator &amp; Formatter
          </h2>
          <p class="text-sm text-muted-foreground" data-i18n="tools.yaml_desc">
            Validate, format, and convert YAML files
          </p>
        </div>
        <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground group-hover:text-primary shrink-0" />
      </Link>

      <Link
        href="/tools/docker-converter"
        class="group flex items-center gap-4 p-4 rounded-lg hover:bg-muted/50 transition-colors"
      >
        <Icon name="lucide:container" class="size-5 text-primary shrink-0" />
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold group-hover:text-primary transition-colors" data-i18n="tools.docker_conv">
            Docker Run to Compose Converter
          </h2>
          <p class="text-sm text-muted-foreground" data-i18n="tools.docker_desc">
            Convert docker run commands to Docker Compose YAML
          </p>
        </div>
        <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground group-hover:text-primary shrink-0" />
      </Link>

      <Link
        href="/tools/ascii-converter"
        class="group flex items-center gap-4 p-4 rounded-lg hover:bg-muted/50 transition-colors"
      >
        <Icon name="lucide:type" class="size-5 text-primary shrink-0" />
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold group-hover:text-primary transition-colors" data-i18n="tools.ascii_conv">
            ASCII Converter
          </h2>
          <p class="text-sm text-muted-foreground" data-i18n="tools.ascii_desc">
            Convert ASCII Text to other structure data
          </p>
        </div>
        <Icon name="lucide:chevron-right" class="size-4 text-muted-foreground group-hover:text-primary shrink-0" />
      </Link>
    </div>
  </article>
</Layout>

