---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import Link from '@/components/Link.astro'
import Layout from '@/layouts/Layout.astro'
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { AUTHOR, SITE, SITE_URL } from '@/consts'
import { Badge } from '@/components/ui/badge'
import { Card, CardContent } from '@/components/ui/card'

// Dynamic experience years (career started Jun 2018)
const yearsExp = new Date().getFullYear() - 2018
// Agrosmart duration: Jun 2018 – Sep 2023 (fixed past job)
const agrosmarYears = 2023 - 2018

// Enhanced Person Schema for About page
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Carlos Alarcon",
  "alternateName": "NullKDev",
  "url": SITE.href,
  "image": new URL('/static/avatar.png', Astro.site).href,
  "jobTitle": "Mobile Developer",
  "worksFor": {
    "@type": "Organization",
    "name": "Corporativo Overall"
  },
  "alumniOf": [
    { "@type": "CollegeOrUniversity", "name": "Universidad Autónoma de Ica" },
    { "@type": "CollegeOrUniversity", "name": "Universidad Alas Peruanas" }
  ],
  "knowsAbout": [
    "Android Development",
    "Kotlin",
    "Java",
    "Flutter",
    "Kotlin Multiplatform",
    "Python",
    "Laravel",
    "Clean Architecture",
    "MVVM",
    "MVI"
  ],
    "sameAs": [
    "https://github.com/NullKDev",
    "https://www.linkedin.com/in/jcarlos-dev/",
    SITE_URL
  ],
  "email": AUTHOR.social.email.mail,
  "description": `Mobile developer with ${yearsExp}+ years of experience specialized in Android, Kotlin, Java, Flutter and KMM. Passionate about creating exceptional user experiences.`
}

const skills = [
  { name: 'Kotlin', icon: 'lucide:code-2' },
  { name: 'Android', icon: 'lucide:smartphone' },
  { name: 'Flutter', icon: 'lucide:layers' },
  { name: 'Java', icon: 'lucide:coffee' },
  { name: 'KMM', icon: 'lucide:blocks' },
  { name: 'Python', icon: 'lucide:terminal' },
  { name: 'Laravel', icon: 'lucide:server' },
  { name: 'TypeScript', icon: 'lucide:file-code' },
]

const architectures = [
  'Clean Architecture',
  'MVVM',
  'MVI',
  'MVP'
]

type AppLink = {
  name: string
  store: 'google' | 'huawei' | 'apk'
  href?: string
}

type ExperienceItem = {
  role: string
  company: string
  period: string
  location: string
  current?: boolean
  icon: string
  desc: string
  descEs: string
  apps?: AppLink[]
}

const experience: ExperienceItem[] = [
  {
    role: 'Mobile Developer',
    company: 'Corporativo Overall',
    period: 'Oct 2023 - Present',
    location: 'Peru · Remote',
    current: true,
    icon: 'lucide:smartphone',
    desc: 'Supporting and growing LiveTrade and LiveTrade Impulso (lite), a trading platform for the Peruvian market. Built with Android SDK and Kotlin — published on Google Play and Huawei AppGallery.',
    descEs: 'Soporte y crecimiento de LiveTrade y LiveTrade Impulso (versión lite), una plataforma de trading para el mercado peruano. Desarrollada con Android SDK y Kotlin — publicada en Google Play y Huawei AppGallery.',
    apps: [
      { name: 'LiveTrade apps', store: 'google', href: 'https://play.google.com/store/apps/developer?id=Corporativo+Overall' },
      { name: 'Livetrade apps', store: 'huawei', href: 'https://appgallery.huawei.com/tab/appdetailCommon%7CC103668187%7Cautomore%7Cdoublecolumncardwithstar%7C903547' }
    ],
  },
  {
    role: 'Mobile Developer',
    company: 'Agrosmart S.A.C.',
    period: 'Jun 2018 - Sep 2023',
    location: 'Ica, Peru · On-site',
    icon: 'lucide:smartphone',
    desc: `${agrosmarYears}+ years building Android apps for the agricultural tech sector from the ground up — Java and Kotlin. Shipped apps on Google Play and maintained internal APKs distributed directly to field teams.`,
    descEs: `Más de ${agrosmarYears} años construyendo apps Android para el sector agrotecnológico desde cero — Java y Kotlin. Apps publicadas en Google Play y APKs internos distribuidos directamente a equipos de campo.`,
    apps: [
      { name: 'Agrosmart apps', store: 'google', href: 'https://play.google.com/store/apps/developer?id=AGROSMART+SAC' },
      { name: 'APKs internos', store: 'apk' },
    ],
  },
]
---

<Layout class="max-w-4xl">
  <PageHead slot="head" title="About" />

  <!-- Person Schema for About page SEO -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:user' }]} />

  <section class="flex flex-col gap-12">
    <!-- Hero Section -->
    <div class="relative">
      <div class="absolute inset-0 bg-gradient-to-r from-primary/5 via-primary/10 to-primary/5 rounded-3xl blur-3xl -z-10"></div>
      
      <Card className="border-0 shadow-lg bg-card/50 backdrop-blur">
        <CardContent className="p-8 md:p-12">
          <div class="flex flex-col md:flex-row gap-8 items-start md:items-center">
            <!-- Avatar with gradient border -->
            <div class="relative group">
              <div class="absolute -inset-1 bg-gradient-to-r from-primary to-primary/50 rounded-2xl blur opacity-25 group-hover:opacity-75 transition duration-500"></div>
              <img
                src="/static/avatar.png"
                alt="Carlos Alarcon"
                width="400"
                height="400"
                class="relative rounded-2xl object-cover w-32 h-32 md:w-40 md:h-40 ring-4 ring-background"
                loading="eager"
                decoding="async"
              />
            </div>

            <!-- Info -->
            <div class="flex-1 space-y-4">
              <div>
                <h1 class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-foreground to-foreground/70 bg-clip-text text-transparent">
                  {personSchema.name}
                </h1>
                <p class="text-lg text-muted-foreground font-mono mt-2">
                  <span class="text-primary/80">aka</span> <span class="text-primary font-semibold">{personSchema.alternateName}</span>
                </p>
              </div>
              
              <div class="flex flex-wrap gap-2">
                <Badge variant="secondary" className="px-3 py-1">
                  <Icon name="lucide:briefcase" class="size-3 mr-1.5" />
                  <span data-i18n="about.job_badge">Android Developer</span>
                </Badge>
                <Badge variant="secondary" className="px-3 py-1">
                  <Icon name="lucide:map-pin" class="size-3 mr-1.5" />
                  <span data-i18n="about.country_badge">Perú</span>
                </Badge>
                <Badge variant="secondary" className="px-3 py-1">
                  <Icon name="lucide:calendar" class="size-3 mr-1.5" />
                  { (new Date()).getFullYear() - 2018 }+ <span data-i18n="about.years_exp">años de experiencia</span>
                </Badge>
              </div>

              <Link
                href={AUTHOR.social.email.href}
                external
                class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 transition-colors font-medium shadow-lg shadow-primary/25"
              >
                <Icon name="lucide:mail" class="size-4" />
                <span data-i18n="about.contact_btn">Contáctame</span>
              </Link>
            </div>
          </div>
        </CardContent>
      </Card>
    </div>

    <!-- About Content -->
    <div class="grid md:grid-cols-3 gap-6">
      <!-- Main Bio -->
      <Card className="md:col-span-2 border-border/50 shadow-sm hover:shadow-md transition-shadow">
        <CardContent className="p-6 md:p-8 space-y-5">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2 bg-primary/10 rounded-lg">
              <Icon name="lucide:user-circle" class="size-5 text-primary" />
            </div>
            <h2 class="text-2xl font-bold" data-i18n="about.about_heading">Sobre mí</h2>
          </div>

          <p class="text-muted-foreground leading-relaxed" data-i18n-html="about.bio_p1">
            Hi! I'm a <strong class="text-foreground">mobile developer</strong> with over 7 years of experience building innovative applications. I currently work at <strong class="text-foreground">Corporativo Overall</strong>, where I drive the growth and development of mobile initiatives.
          </p>

          <p class="text-muted-foreground leading-relaxed" data-i18n-html="about.bio_p2">
            I specialize in <strong class="text-foreground">native Android development</strong> using modern technologies like <strong class="text-foreground">Kotlin</strong>, <strong class="text-foreground">Java</strong>, <strong class="text-foreground">Flutter</strong>, and <strong class="text-foreground">Kotlin Multiplatform</strong>. My ability to learn new technologies allows me to stay up to date with market trends and ensure success in mobile development.
          </p>

          <p class="text-muted-foreground leading-relaxed" data-i18n-html="about.bio_p3">
            Beyond mobile, I also have skills in <strong class="text-foreground">Python</strong>, <strong class="text-foreground">Laravel</strong>, database administration, and more. I'm always looking for opportunities to collaborate with dynamic teams on projects that transform and improve the user experience.
          </p>
        </CardContent>
      </Card>

      <!-- Quick Stats -->
      <div class="space-y-6">
        <Card className="border-border/50 shadow-sm hover:shadow-md transition-shadow">
          <CardContent className="p-6 space-y-4">
            <div class="flex items-center gap-3">
              <div class="p-2 bg-primary/10 rounded-lg">
                <Icon name="lucide:rocket" class="size-5 text-primary" />
              </div>
              <h3 class="font-bold" data-i18n="about.stack_title">Stack Principal</h3>
            </div>
            <div class="grid grid-cols-2 gap-2">
              {skills.map(skill => (
                <div class="flex items-center gap-2 p-2 rounded-lg bg-secondary/50 hover:bg-secondary transition-colors">
                  <Icon name={skill.icon} class="size-4 text-primary" />
                  <span class="text-sm font-medium">{skill.name}</span>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>

        <Card className="border-border/50 shadow-sm hover:shadow-md transition-shadow">
          <CardContent className="p-6 space-y-4">
            <div class="flex items-center gap-3">
              <div class="p-2 bg-primary/10 rounded-lg">
                <Icon name="lucide:boxes" class="size-5 text-primary" />
              </div>
              <h3 class="font-bold" data-i18n="about.arch_title">Arquitecturas</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {architectures.map(arch => (
                <Badge variant="outline" className="font-normal">
                  {arch}
                </Badge>
              ))}
            </div>
          </CardContent>
        </Card>
      </div>
    </div>

      <!-- Experience Timeline -->
  <section class="mt-8">
    <div class="mb-6">
      <h2 class="text-2xl font-semibold mb-2" data-i18n="about.exp_heading">Experience</h2>
      <p class="text-sm text-muted-foreground"
        data-i18n-exp-en={`${yearsExp}+ years in mobile development across Android, Flutter and multiplatform technologies`}
        data-i18n-exp-es={`${yearsExp}+ años en desarrollo móvil con Android, Flutter y tecnologías multiplataforma`}
      >
        {yearsExp}+ years in mobile development across Android, Flutter and multiplatform technologies
      </p>
    </div>

    <div class="space-y-6">
      {experience.map((exp, index) => (
        <div class="relative">
          {index < experience.length - 1 && (
            <div class="absolute left-[11px] top-8 bottom-0 w-px bg-border" aria-hidden="true"></div>
          )}

          <div class="flex gap-4">
            <div class={cn(
              "relative flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center ring-4 ring-background z-10",
              exp.current ? "bg-primary text-primary-foreground shadow-lg shadow-primary/20" : "bg-muted text-muted-foreground"
            )}>
              <Icon name={exp.icon} class="size-3.5" />
            </div>

            <div class="flex-1 pb-2 min-w-0">
              <div class="mb-1">
                <h3 class="font-semibold text-lg leading-tight">{exp.role}</h3>
                <p class="text-sm text-muted-foreground">
                  {exp.company} · {exp.period}
                </p>
                <p class="text-xs text-muted-foreground/70 mt-0.5">
                  {exp.location}
                </p>
              </div>
              <p class="text-sm text-muted-foreground/90 leading-relaxed mt-2" data-i18n-exp-en={exp.desc} data-i18n-exp-es={exp.descEs}>
                {exp.desc}
              </p>
              {exp.apps && exp.apps.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-3">
                  {exp.apps.map((app) => (
                    app.href ? (
                      <a
                        href={app.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-secondary/60 text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors border border-border/40"
                      >
                        {app.store === 'google' && <Icon name="lucide:play" class="size-3" />}
                        {app.store === 'huawei' && <Icon name="lucide:smartphone" class="size-3" />}
                        {app.store === 'apk' && <Icon name="lucide:package" class="size-3" />}
                        {app.store === 'google' ? 'Google Play' : app.store === 'huawei' ? 'Huawei AppGallery' : 'APK'}
                        <Icon name="lucide:external-link" class="size-2.5 opacity-60" />
                      </a>
                    ) : (
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-secondary/60 text-muted-foreground border border-border/40">
                        {app.store === 'google' && <Icon name="lucide:play" class="size-3" />}
                        {app.store === 'huawei' && <Icon name="lucide:smartphone" class="size-3" />}
                        {app.store === 'apk' && <Icon name="lucide:package" class="size-3" />}
                        {app.store === 'google' ? 'Google Play' : app.store === 'huawei' ? 'Huawei AppGallery' : 'APK directo'}
                      </span>
                    )
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

    <!-- Now -->
    <section>
      <div class="flex items-center gap-2 mb-4">
        <Icon name="lucide:clock" class="size-4 text-primary" />
        <h2 class="text-lg font-semibold" data-i18n="about.now_heading">Now</h2>
        <span class="text-xs text-muted-foreground/60 ml-auto" data-i18n="about.now_updated">Apr 2025</span>
      </div>
      <ul class="space-y-2 text-sm text-muted-foreground">
        <li class="flex gap-2">
          <span class="text-primary shrink-0">—</span>
          <span data-i18n-html="about.now_1">Mobile dev at <strong style="color:inherit;font-weight:600">Corporativo Overall</strong> — Android & KMP in production.</span>
        </li>
        <li class="flex gap-2">
          <span class="text-primary shrink-0">—</span>
          <span data-i18n-html="about.now_2">Migrating to <strong style="color:inherit;font-weight:600">Jetpack Compose</strong> and exploring <strong style="color:inherit;font-weight:600">KMP</strong>.</span>
        </li>
        <li class="flex gap-2">
          <span class="text-primary shrink-0">—</span>
          <span data-i18n="about.now_3">Building this site and writing about Android development.</span>
        </li>
      </ul>
    </section>

    <!-- Uses -->
    <section>
      <div class="flex items-center gap-2 mb-4">
        <Icon name="lucide:wrench" class="size-4 text-primary" />
        <h2 class="text-lg font-semibold" data-i18n="about.uses_heading">Uses</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-1.5 text-sm">
        {[
          { label: 'Editor', value: 'Android Studio · VS Code' },
          { label: 'Stack', value: 'Kotlin · Flutter · KMM' },
          { label: 'Terminal', value: 'WSL2 · Zsh + Oh My Zsh' },
          { label: 'Font', value: 'JetBrains Mono' },
          { label: 'Theme', value: 'Material Theme Dark' },
          { label: 'Tools', value: 'Notion · Figma · Postman' },
        ].map(({ label, value }) => (
          <div class="flex gap-2">
            <span class="text-muted-foreground/60 shrink-0 w-16">{label}</span>
            <span class="text-muted-foreground">{value}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Fun Fact / Origin Story -->
    <Card className="border-primary/20 bg-gradient-to-br from-primary/5 to-transparent shadow-sm">
      <CardContent className="p-6 md:p-8">
        <div class="flex items-start gap-4">
          <div class="p-3 bg-primary/10 rounded-xl shrink-0">
            <Icon name="lucide:sparkles" class="size-6 text-primary" />
          </div>
          <div class="space-y-2">
            <h3 class="text-lg font-bold" data-i18n="about.origin_title">¿Por qué NullKDev?</h3>
            <p class="text-muted-foreground leading-relaxed" data-i18n-html="about.origin_desc">
              El nombre <strong class="text-foreground">NullKDev</strong> representa mi identidad como desarrollador: <strong class="text-foreground">Null</strong> por el concepto fundamental en programación, <strong class="text-foreground">K</strong> por <strong class="text-foreground">Kotlin</strong> (mi lenguaje favorito) y también por <strong class="text-foreground">Karl</strong>, y <strong class="text-foreground">Dev</strong> por desarrollador. Es mi forma de expresar mi pasión por el código limpio y las soluciones elegantes.
            </p>
          </div>
        </div>
      </CardContent>
    </Card>

  </section>
</Layout>

<script is:inline define:vars={{ yearsExp }} data-astro-rerun>
  window.__i18nVars = window.__i18nVars || {}
  window.__i18nVars.yearsExp = yearsExp
</script>

<script is:inline data-astro-rerun>
  (function () {
    function applyExpI18n(lang) {
      document.querySelectorAll('[data-i18n-exp-en]').forEach(function (el) {
        var text = lang === 'es'
          ? el.getAttribute('data-i18n-exp-es')
          : el.getAttribute('data-i18n-exp-en')
        if (text) el.textContent = text
      })
    }
    applyExpI18n(localStorage.getItem('lang') || 'en')
    window.addEventListener('locale-changed', function (e) {
      applyExpI18n(e.detail.locale)
    })
    document.addEventListener('astro:after-swap', function () {
      applyExpI18n(localStorage.getItem('lang') || 'en')
    })
  })()
</script>