---
import BlogCard from '@/components/BlogCard.astro'
import HomeSectionHeading from '@/components/HomeSectionHeading.astro'
import HomeStatsBar from '@/components/HomeStatsBar.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { getRecentPosts, getAllProjects } from '@/lib/data-utils'
import { cn } from '@/lib/utils'
import { SITE, AUTHOR } from '@/consts'

let latestPosts: Awaited<ReturnType<typeof getRecentPosts>> = []
try { latestPosts = await getRecentPosts(3) } catch (e) {}

let featuredProjects: Awaited<ReturnType<typeof getAllProjects>> = []
try { featuredProjects = (await getAllProjects()).filter(p => !p.data.protected).slice(0, 4) } catch (e) {}

const yearsExp = new Date().getFullYear() - 2018
const sevenDaysMs = 7 * 24 * 60 * 60 * 1000

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Carlos Alarcon',
  alternateName: 'NullKDev',
  url: SITE.href,
  image: new URL(AUTHOR.avatar, Astro.site).href,
  jobTitle: 'Mobile Developer',
  knowsAbout: ['Android', 'Kotlin', 'Flutter', 'Java', 'KMM', 'Python', 'Laravel'],
  sameAs: ['https://github.com/NullKDev', 'https://www.linkedin.com/in/jcarlos-dev/'],
  description: SITE.description,
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.title,
  url: SITE.href,
  description: SITE.description,
}

const stack = ['Kotlin', 'Android', 'Flutter', 'Java', 'KMM', 'Python', 'Laravel']

const whatIDo = [
  {
    icon: 'lucide:smartphone',
    color: 'text-primary',
    bg: 'bg-primary/10',
    border: 'border-l-primary',
    titleKey: 'home.do_mobile_title',
    title: 'Mobile Apps',
    descKey: 'home.do_mobile_desc',
    desc: 'Native Android apps with Kotlin & Java. Performance-first, clean architecture.',
  },
  {
    icon: 'lucide:layers',
    color: 'text-purple-500',
    bg: 'bg-purple-500/10',
    border: 'border-l-purple-500',
    titleKey: 'home.do_cross_title',
    title: 'Cross-Platform',
    descKey: 'home.do_cross_desc',
    desc: 'Flutter & Kotlin Multiplatform — one codebase, iOS and Android.',
  },
  {
    icon: 'lucide:terminal',
    color: 'text-emerald-500',
    bg: 'bg-emerald-500/10',
    border: 'border-l-emerald-500',
    titleKey: 'home.do_other_title',
    title: 'Backend & Tools',
    descKey: 'home.do_other_desc',
    desc: 'Python scripts, Laravel APIs, and developer tooling when the project calls for it.',
  },
]
---

<Layout class="max-w-3xl" transition:persist="home-layout">
  <PageHead slot="head" title={SITE.title} fullTitle={true} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- ── HERO ── -->
  <section class="relative -mx-4 sm:-mx-6 md:-mx-8 mb-10 overflow-hidden">
    <!-- Background mesh -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/8 via-background to-purple-500/6"></div>
    <div class="absolute -top-20 right-0 w-[500px] h-[500px] bg-primary/12 rounded-full blur-[100px]"></div>
    <div class="absolute -bottom-20 -left-10 w-[400px] h-[400px] bg-purple-500/10 rounded-full blur-[90px]"></div>
    <div class="absolute inset-0 bg-grid-pattern [mask-image:radial-gradient(ellipse_at_center,white,transparent_72%)]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-background/80"></div>

    <div class="relative px-4 sm:px-6 md:px-8 py-5 sm:py-7 md:py-8">
      <div class="max-w-3xl mx-auto">
        <div class="flex flex-col-reverse sm:flex-row items-start sm:items-center justify-between gap-8 sm:gap-12">

          <!-- Text -->
          <div class="flex-1 space-y-5 animate-fade-up">
            <!-- Available badge -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-background/80 backdrop-blur-sm border border-primary/20 shadow-sm">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
              </span>
              <span class="text-xs font-medium text-foreground" data-i18n="common.available">Available for opportunities</span>
            </div>

            <!-- Name + subtitle -->
            <div class="space-y-2">
              <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-none">
                Carlos<span class="gradient-text">Dev</span>
              </h1>
              <p class="text-base sm:text-lg font-medium text-muted-foreground" data-i18n="home.subtitle">
                Mobile Developer · Android · Flutter · KMM
              </p>
              <p class="text-sm text-muted-foreground/80 leading-relaxed max-w-lg" data-i18n="home.bio">
                {yearsExp}+ years building mobile apps. Kotlin and Flutter are my daily tools.
              </p>
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-3 animate-fade-up animation-delay-200">
              <Link href="/projects" class={cn(buttonVariants({ size: 'default' }), 'group shadow-md shadow-primary/15')}>
                <Icon name="lucide:git-merge" class="size-4" />
                <span data-i18n="home.cta_projects">View projects</span>
                <Icon name="lucide:arrow-right" class="size-4 group-hover:translate-x-1 transition-transform" />
              </Link>
              <Link href="/about" class={buttonVariants({ variant: 'outline', size: 'default' })}>
                <span data-i18n="home.cta_about">About me</span>
              </Link>
            </div>

            <!-- Social links -->
            <div class="flex items-center gap-1 animate-fade-up animation-delay-300">
              {Object.values(AUTHOR.social).filter(s => ['github','linkedin','email'].includes(s.label.toLowerCase())).map((s) => (
                <Link
                  href={s.href}
                  class="inline-flex items-center justify-center size-8 rounded-lg text-muted-foreground hover:text-foreground hover:bg-muted transition-all"
                  aria-label={s.label}
                >
                  <Icon name={s.icon} class="size-4" />
                </Link>
              ))}
            </div>
          </div>

          <!-- Avatar -->
          <div class="relative flex-shrink-0 self-center sm:self-auto animate-fade-in animation-delay-100">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/30 to-purple-500/25 rounded-full blur-2xl scale-110 opacity-60"></div>
            <div class="relative w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden ring-4 ring-primary/20 ring-offset-4 ring-offset-background shadow-2xl">
              <img
                src={AUTHOR.avatar}
                alt={SITE.author}
                width="160"
                height="160"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover"
              />
            </div>
            <!-- Decorative dashed ring -->
            <div class="absolute -inset-3 rounded-full border border-primary/15 border-dashed pointer-events-none"></div>
          </div>
        </div>

        <!-- Stack pills -->
        <div class="mt-6 pt-6 border-t border-border/40 animate-fade-up animation-delay-400">
          <p class="text-[10px] text-muted-foreground/50 uppercase tracking-widest mb-3 font-semibold" data-i18n="home.core_stack">Core Stack</p>
          <div class="flex flex-wrap gap-2">
            {stack.map((tech) => (
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-muted/40 border border-border/50 text-xs font-medium text-muted-foreground hover:border-primary/40 hover:text-foreground hover:bg-primary/5 transition-all cursor-default">
                <span class="w-1.5 h-1.5 rounded-full bg-primary/60 shrink-0"></span>
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHAT I DO ── -->
  <section class="mb-8">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {whatIDo.map((item, i) => (
        <div
          class={`relative overflow-hidden rounded-xl border border-border/40 border-l-4 ${item.border} bg-card/50 p-5 space-y-3 hover:shadow-md hover:bg-card/80 transition-all duration-200 animate-fade-up`}
          style={`animation-delay: ${i * 80}ms`}
        >
          <!-- Watermark icon -->
          <div class={`absolute -right-3 -top-3 ${item.color} pointer-events-none`}>
            <Icon name={item.icon} class="size-20 opacity-[0.045]" />
          </div>

          <div class={`relative inline-flex p-2.5 rounded-lg ${item.bg} ${item.color}`}>
            <Icon name={item.icon} class="size-5" />
          </div>
          <div class="relative space-y-1.5">
            <h3 class="text-sm font-semibold text-foreground" data-i18n={item.titleKey}>{item.title}</h3>
            <p class="text-xs text-muted-foreground leading-relaxed" data-i18n={item.descKey}>{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── STATS ── -->
  <section class="mb-8">
    <HomeStatsBar yearsExp={yearsExp} />
  </section>

  <!-- ── LATEST POSTS ── -->
  {latestPosts.length > 0 && (
    <section class="mb-8">
      <HomeSectionHeading
        titleKey="home.latest_posts"
        titleDefault="Latest Posts"
        linkHref="/blog"
        linkKey="home.view_all"
        linkDefault="View all"
      />
      <div class="space-y-3">
        {latestPosts.map((post, i) => {
          const isNew = (Date.now() - post.data.date.getTime()) < sevenDaysMs
          return (
            <article class={`relative animate-fade-up`} style={`animation-delay: ${i * 60}ms`}>
              {isNew && i === 0 && (
                <span class="absolute -top-1.5 -right-1 z-10 text-[9px] font-bold px-1.5 py-0.5 rounded bg-primary text-primary-foreground tracking-wider" data-i18n="home.new_badge">NEW</span>
              )}
              <BlogCard entry={post} />
            </article>
          )
        })}
      </div>
    </section>
  )}

  <!-- ── FEATURED PROJECTS ── -->
  {featuredProjects.length > 0 && (
    <section class="mb-8">
      <HomeSectionHeading
        titleKey="home.featured_projects"
        titleDefault="Featured Projects"
        linkHref="/projects"
        linkKey="home.view_all_projects"
        linkDefault="View all projects"
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {featuredProjects.map((project, i) => (
          <div class="animate-fade-up" style={`animation-delay: ${i * 80}ms`}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ── CONNECT CTA ── -->
  <section class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-border/50 bg-card/40 p-7 sm:p-9">
      <!-- Stronger gradient blobs -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary/8 via-transparent to-purple-500/8 pointer-events-none"></div>
      <div class="absolute top-0 left-1/4 w-64 h-64 bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-0 right-1/4 w-56 h-56 bg-purple-500/8 rounded-full blur-3xl pointer-events-none"></div>
      <!-- Top border accent -->
      <div class="absolute top-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent pointer-events-none"></div>

      <div class="relative space-y-5">
        <div class="space-y-2">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-i18n="home.connect_title">
            Let's connect
          </h2>
          <p class="text-sm text-muted-foreground leading-relaxed max-w-md" data-i18n="home.connect_desc">
            Open to mobile development projects, Android consulting, or just talking code.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <Link href={AUTHOR.social.email.href} class={cn(buttonVariants({ size: 'default' }), 'group shadow-md shadow-primary/10')}>
            <Icon name="lucide:mail" class="size-4" />
            <span data-i18n="home.send_email">Send email</span>
            <Icon name="lucide:arrow-right" class="size-4 group-hover:translate-x-1 transition-transform" />
          </Link>
          <Link href="/about" class={buttonVariants({ variant: 'outline', size: 'default' })}>
            <span data-i18n="home.view_experience">View experience</span>
          </Link>
        </div>

        <!-- Social links row -->
        <div class="flex items-center gap-2 pt-1 border-t border-border/30">
          {Object.values(AUTHOR.social).filter(s => ['github','linkedin','rss'].includes(s.label.toLowerCase())).map((s) => (
            <Link
              href={s.href}
              class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs text-muted-foreground hover:text-foreground hover:bg-muted transition-all"
              aria-label={s.label}
              {...(s.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <Icon name={s.icon} class="size-3.5" />
              <span>{s.label}</span>
            </Link>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(15 23 42 / 0.04)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
  }
  [data-theme='dark'] .bg-grid-pattern {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(241 245 249 / 0.04)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
  }
</style>
