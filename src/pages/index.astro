---
import BlogCard from '@/components/BlogCard.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { getRecentPosts } from '@/lib/data-utils'
import { cn } from '@/lib/utils'
import { SITE, AUTHOR } from '@/consts'

let latestPosts: Awaited<ReturnType<typeof getRecentPosts>> = []
try {
  latestPosts = await getRecentPosts(3)
} catch (error) {
  console.error('Error fetching recent posts:', error)
}

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Carlos Alarcon",
  "alternateName": "NullKDev",
  "url": SITE.href,
  "image": new URL(AUTHOR.avatar, Astro.site).href,
  "jobTitle": "Software Developer & System Engineer",
  "knowsAbout": [
    "Linux Administration",
    "Kubernetes",
    "HPC Systems",
    "Network Security",
    "Infrastructure Automation",
    "Homelab"
  ],
  "sameAs": [
    "https://github.com/NullKDev",
    "https://www.linkedin.com/in/jcarlos-dev/"
  ],
  "description": SITE.description
}

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": SITE.title,
  "url": SITE.href,
  "description": SITE.description
}
---

<Layout class="max-w-5xl" transition:persist="home-layout">
  <PageHead slot="head" title={SITE.title} fullTitle={true} />
  
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Hero Premium -->
  <section class="relative -mx-4 sm:-mx-6 md:-mx-8 mb-16 overflow-hidden">
    <!-- Background con gradientes y blur -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-background to-purple-500/5"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-background/50 via-background/80 to-background"></div>
    
    <!-- Grid pattern sutil -->
    <div class="absolute inset-0 bg-grid-slate-900/[0.02] dark:bg-grid-slate-100/[0.02] [mask-image:radial-gradient(ellipse_at_center,white,transparent_75%)]"></div>

    <!-- Contenido -->
    <div class="relative px-4 sm:px-6 md:px-8 py-16 sm:py-20 md:py-24">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col-reverse sm:flex-row items-start sm:items-center justify-between gap-8">
          <!-- Texto principal -->
          <div class="flex-1 space-y-6">
            <!-- Badge de status -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-background/80 backdrop-blur-sm border border-primary/20 shadow-lg shadow-primary/5">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
              </span>
              <span class="text-xs font-medium text-foreground">Available for opportunities</span>
            </div>

            <!-- Heading principal -->
            <div class="space-y-3">
              <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-none">
                {SITE.title}
              </h1>
              <p class="text-lg sm:text-xl md:text-2xl text-muted-foreground leading-relaxed max-w-2xl">
                Software Developer .
              </p>
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-3 pt-2">
              <Link 
                href="/blog" 
                class={cn(buttonVariants({ size: 'lg' }), 'group shadow-lg shadow-primary/20')}
              >
                <Icon name="lucide:book-open" class="size-4" />
                <span>Read guides</span>
                <Icon name="lucide:arrow-right" class="size-4 group-hover:translate-x-1 transition-transform" />
              </Link>
              <Link 
                href="/about" 
                class={buttonVariants({ variant: 'outline', size: 'lg' })}
              >
                <span>Learn more</span>
              </Link>
            </div>
          </div>

          <!-- Avatar con efecto -->
          <div class="relative flex-shrink-0">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/30 to-purple-500/30 rounded-2xl blur-2xl"></div>
            <div class="relative w-32 h-32 sm:w-40 sm:h-40 rounded-2xl overflow-hidden border-2 border-primary/20 shadow-2xl">
              <img
                src={AUTHOR.avatar}
                alt={SITE.author}
                width="160"
                height="160"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>

        <!-- Stack tecnológico - Visual badges -->
        <div class="mt-12 pt-8 border-t border-border/50">
          <p class="text-sm text-muted-foreground uppercase tracking-wide mb-4">Core Stack</p>
          <div class="flex flex-wrap gap-2">
            {['Linux', 'Kubernetes', 'HPC', 'Security', 'Python', 'Automation'].map((tech) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-muted/50 border border-border/50 text-sm font-medium hover:border-primary/30 hover:bg-muted transition-all">
                <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Posts - Compacto -->
  {latestPosts && latestPosts.length > 0 && (
    <section class="mb-16">
      <div class="flex items-end justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold">Latest Posts</h2>
          <p class="text-sm text-muted-foreground mt-1">Recent guides and tutorials</p>
        </div>
        <Link 
          href="/blog" 
          class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-primary transition-colors"
        >
          <span>View all</span>
          <Icon name="lucide:arrow-right" class="size-3.5" />
        </Link>
      </div>
      
      <div class="space-y-4">
        {latestPosts.map((post) => (
          <article>
            <BlogCard entry={post} />
          </article>
        ))}
      </div>

      <div class="mt-6 sm:hidden">
        <Link 
          href="/blog" 
          class="flex items-center justify-center gap-2 py-3 px-4 rounded-lg border border-border/50 bg-muted/20 hover:bg-muted/40 hover:border-primary/30 text-sm font-medium transition-all"
        >
          <span>View all posts</span>
          <Icon name="lucide:arrow-right" class="size-4" />
        </Link>
      </div>
    </section>
  )}

  <!-- Featured Content Grid -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold mb-6">Explore</h2>
    
    <div class="grid sm:grid-cols-2 gap-4">
      <!-- About Card -->
      <Link
        href="/about"
        class="group relative overflow-hidden rounded-xl border border-border/50 bg-gradient-to-br from-background via-muted/20 to-background p-6 hover:border-primary/30 transition-all hover:shadow-lg"
      >
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-primary/10 to-transparent rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="relative space-y-3">
          <div class="inline-flex p-2 rounded-lg bg-primary/10 text-primary">
            <Icon name="lucide:user" class="size-5" />
          </div>
          <h3 class="text-lg font-semibold">About</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Experience, skills, and background in system administration and security
          </p>
          <div class="flex items-center gap-1.5 text-sm font-medium text-primary pt-1">
            <span>Learn more</span>
            <Icon name="lucide:arrow-right" class="size-4 group-hover:translate-x-1 transition-transform" />
          </div>
        </div>
      </Link>

      <!-- Projects Card -->
      <Link
        href="/blog"
        class="group relative overflow-hidden rounded-xl border border-border/50 bg-gradient-to-br from-background via-muted/20 to-background p-6 hover:border-primary/30 transition-all hover:shadow-lg"
      >
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-purple-500/10 to-transparent rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="relative space-y-3">
          <div class="inline-flex p-2 rounded-lg bg-purple-500/10 text-purple-500">
            <Icon name="lucide:layers" class="size-5" />
          </div>
          <h3 class="text-lg font-semibold">Projects</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Infrastructure setups, homelab experiments, and technical write-ups
          </p>
          <div class="flex items-center gap-1.5 text-sm font-medium text-primary pt-1">
            <span>Explore</span>
            <Icon name="lucide:arrow-right" class="size-4 group-hover:translate-x-1 transition-transform" />
          </div>
        </div>
      </Link>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="mb-16">
    <div class="relative overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-br from-muted/30 via-background to-muted/30 p-8 sm:p-10">
      <!-- Decorative blurs -->
      <div class="absolute top-0 left-1/3 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/3 w-64 h-64 bg-purple-500/5 rounded-full blur-3xl"></div>
      
      <div class="relative max-w-2xl space-y-5">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
          Let's connect
        </h2>
        <p class="text-lg text-muted-foreground leading-relaxed">
          Open to discussing infrastructure projects, security challenges, or sharing homelab experiences.
        </p>
        
        <div class="flex flex-wrap gap-3 pt-2">
          <Link 
            href={AUTHOR.social.email.href}
            class={cn(buttonVariants({ size: 'lg' }), 'group')}
          >
            <Icon name="lucide:mail" class="size-4" />
            <span>Send email</span>
            <Icon name="lucide:arrow-right" class="size-4 group-hover:translate-x-1 transition-transform" />
          </Link>
          <Link 
            href="/about" 
            class={buttonVariants({ variant: 'outline', size: 'lg' })}
          >
            <span>View experience</span>
          </Link>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Grid pattern para el fondo */
  .bg-grid-slate-900\/\[0\.02\] {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(15 23 42 / 0.02)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
  }
  
  .dark .bg-grid-slate-100\/\[0\.02\] {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(241 245 249 / 0.02)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
  }
</style>