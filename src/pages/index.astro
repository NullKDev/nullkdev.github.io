---
import BlogCard from '@/components/BlogCard.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { getRecentPosts, getAllProjects } from '@/lib/data-utils'
import { cn } from '@/lib/utils'
import { SITE, AUTHOR } from '@/consts'

let latestPosts: Awaited<ReturnType<typeof getRecentPosts>> = []
try {
  latestPosts = await getRecentPosts(3)
} catch (e) {}

let featuredProjects: Awaited<ReturnType<typeof getAllProjects>> = []
try {
  featuredProjects = (await getAllProjects()).slice(0, 3)
} catch (e) {}

const yearsExp = new Date().getFullYear() - 2018

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Carlos Alarcon',
  alternateName: 'NullKDev',
  url: SITE.href,
  image: new URL(AUTHOR.avatar, Astro.site).href,
  jobTitle: 'Mobile Developer',
  knowsAbout: ['Android', 'Kotlin', 'Flutter', 'Java', 'KMM', 'Python', 'Laravel'],
  sameAs: ['https://github.com/NullKDev', 'https://www.linkedin.com/in/jcarlos-dev/'],
  description: SITE.description,
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.title,
  url: SITE.href,
  description: SITE.description,
}

const stack = ['Android', 'Kotlin', 'Flutter', 'Java', 'KMM', 'Python', 'Laravel']

const whatIDo = [
  {
    icon: 'lucide:smartphone',
    color: 'text-primary',
    bg: 'bg-primary/10',
    titleKey: 'home.do_mobile_title',
    title: 'Mobile Apps',
    descKey: 'home.do_mobile_desc',
    desc: 'Native Android apps with Kotlin & Java. Performance-first, clean architecture.',
  },
  {
    icon: 'lucide:layers',
    color: 'text-purple-500',
    bg: 'bg-purple-500/10',
    titleKey: 'home.do_cross_title',
    title: 'Cross-Platform',
    descKey: 'home.do_cross_desc',
    desc: 'Flutter & Kotlin Multiplatform — one codebase, iOS and Android.',
  },
  {
    icon: 'lucide:terminal',
    color: 'text-emerald-500',
    bg: 'bg-emerald-500/10',
    titleKey: 'home.do_other_title',
    title: 'Backend & Tools',
    descKey: 'home.do_other_desc',
    desc: 'Python scripts, Laravel APIs, and developer tooling when the project calls for it.',
  },
]
---

<Layout class="max-w-3xl" transition:persist="home-layout">
  <PageHead slot="head" title={SITE.title} fullTitle={true} />
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- ── HERO ── -->
  <section class="relative -mx-4 sm:-mx-6 md:-mx-8 mb-14 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-background to-purple-500/5"></div>
    <div class="absolute top-0 right-1/4 w-80 h-80 bg-primary/8 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 w-80 h-80 bg-purple-500/8 rounded-full blur-3xl"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-background/40 via-background/70 to-background"></div>
    <div class="absolute inset-0 bg-grid-pattern [mask-image:radial-gradient(ellipse_at_center,white,transparent_70%)]"></div>

    <div class="relative px-4 sm:px-6 md:px-8 py-14 sm:py-18 md:py-22">
      <div class="max-w-3xl mx-auto">
        <div class="flex flex-col-reverse sm:flex-row items-start sm:items-center justify-between gap-8">

          <!-- Text -->
          <div class="flex-1 space-y-5">
            <!-- Available badge -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-background/80 backdrop-blur-sm border border-primary/20 shadow-md shadow-primary/5">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
              </span>
              <span class="text-xs font-medium text-foreground" data-i18n="common.available">Available for opportunities</span>
            </div>

            <!-- Name + title -->
            <div class="space-y-2">
              <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-none">
                {SITE.title}
              </h1>
              <p class="text-base sm:text-lg text-muted-foreground font-medium" data-i18n="home.subtitle">
                Mobile Developer · Android · Flutter · KMM
              </p>
              <p class="text-sm text-muted-foreground/80 leading-relaxed max-w-md" data-i18n="home.bio">
                {yearsExp}+ years building mobile apps. Kotlin and Flutter are my daily tools.
              </p>
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-3">
              <Link href="/projects" class={cn(buttonVariants({ size: 'default' }), 'group shadow-md shadow-primary/15')}>
                <Icon name="lucide:git-merge" class="size-4" />
                <span data-i18n="home.cta_projects">View projects</span>
                <Icon name="lucide:arrow-right" class="size-4 group-hover:translate-x-1 transition-transform" />
              </Link>
              <Link href="/about" class={buttonVariants({ variant: 'outline', size: 'default' })}>
                <span data-i18n="home.cta_about">About me</span>
              </Link>
            </div>

            <!-- Social icons -->
            <div class="flex items-center gap-1">
              {Object.values(AUTHOR.social).filter(s => ['github','linkedin','email'].includes(s.label.toLowerCase())).map((s) => (
                <Link
                  href={s.href}
                  class="inline-flex items-center justify-center size-8 rounded-lg text-muted-foreground hover:text-foreground hover:bg-muted transition-all"
                  aria-label={s.label}
                >
                  <Icon name={s.icon} class="size-4" />
                </Link>
              ))}
            </div>
          </div>

          <!-- Avatar -->
          <div class="relative flex-shrink-0">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/25 to-purple-500/25 rounded-2xl blur-xl"></div>
            <div class="relative w-28 h-28 sm:w-36 sm:h-36 rounded-2xl overflow-hidden border-2 border-primary/20 shadow-xl">
              <img
                src={AUTHOR.avatar}
                alt={SITE.author}
                width="144"
                height="144"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>

        <!-- Stack pills -->
        <div class="mt-4 pt-6 border-t border-border/40">
          <p class="text-xs text-muted-foreground/60 uppercase tracking-widest mb-3 font-medium" data-i18n="home.core_stack">Core Stack</p>
          <div class="flex flex-wrap gap-2">
            {stack.map((tech) => (
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-muted/50 border border-border/50 text-xs font-medium text-muted-foreground hover:border-primary/30 hover:text-foreground hover:bg-muted transition-all">
                <span class="w-1 h-1 rounded-full bg-primary/70 shrink-0"></span>
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHAT I DO ── -->
  <section class="mb-14">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {whatIDo.map((item) => (
        <div class="rounded-xl border border-border/40 bg-card/40 p-4 space-y-2.5 hover:border-border/70 hover:bg-muted/10 transition-all">
          <div class={`inline-flex p-2 rounded-lg ${item.bg} ${item.color}`}>
            <Icon name={item.icon} class="size-5" />
          </div>
          <h3 class="text-sm font-semibold text-foreground" data-i18n={item.titleKey}>{item.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed" data-i18n={item.descKey}>{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── LATEST POSTS ── -->
  {latestPosts.length > 0 && (
    <section class="mb-14">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold" data-i18n="home.latest_posts">Latest Posts</h2>
        <Link href="/blog" class="inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-primary transition-colors">
          <span data-i18n="home.view_all">View all</span>
          <Icon name="lucide:arrow-right" class="size-3" />
        </Link>
      </div>
      <div class="space-y-3">
        {latestPosts.map((post) => (
          <article><BlogCard entry={post} /></article>
        ))}
      </div>
    </section>
  )}

  <!-- ── FEATURED PROJECTS ── -->
  {featuredProjects.length > 0 && (
    <section class="mb-14">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold" data-i18n="home.featured_projects">Featured Projects</h2>
        <Link href="/projects" class="inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-primary transition-colors">
          <span data-i18n="home.view_all">View all</span>
          <Icon name="lucide:arrow-right" class="size-3" />
        </Link>
      </div>

      <div class="flex flex-col gap-2.5">
        {featuredProjects.map((project) => {
          const locale = project.data.lang === 'es' ? 'es' : 'en'
          const url = locale === 'es' ? `/es/projects/${project.id.replace(/\.es(\/|$)/, '$1')}` : `/projects/${project.id}`
          const startYear = project.data.startDate ? new Date(project.data.startDate).getFullYear() : null
          return (
            <Link
              href={url}
              class="group flex items-center gap-4 p-3.5 rounded-xl border border-border/40 bg-card/40 hover:border-primary/30 hover:bg-muted/10 hover:shadow-sm transition-all duration-200"
            >
              <!-- Icon placeholder or first tag indicator -->
              <div class="shrink-0 w-9 h-9 rounded-lg bg-primary/10 border border-border/30 flex items-center justify-center">
                <Icon name="lucide:git-merge" class="size-4 text-primary/60" />
              </div>

              <!-- Info -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors truncate">
                    {project.data.title}
                  </span>
                  {startYear && (
                    <span class="text-[10px] text-muted-foreground/60 shrink-0">{startYear}</span>
                  )}
                </div>
                <p class="text-xs text-muted-foreground line-clamp-1 mt-0.5">{project.data.description}</p>
              </div>

              <!-- Tags -->
              <div class="hidden sm:flex items-center gap-1.5 shrink-0">
                {(project.data.tags ?? []).slice(0, 2).map((tag: string) => (
                  <span class="text-[10px] px-1.5 py-0.5 rounded bg-secondary/50 text-muted-foreground border border-border/30">
                    {tag}
                  </span>
                ))}
              </div>

              <Icon name="lucide:arrow-right" class="size-3.5 text-muted-foreground/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all shrink-0" />
            </Link>
          )
        })}
      </div>
    </section>
  )}

  <!-- ── CONNECT CTA ── -->
  <section class="mb-12">
    <div class="relative overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-br from-muted/20 via-background to-muted/20 p-7 sm:p-9">
      <div class="absolute top-0 left-1/3 w-48 h-48 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/3 w-48 h-48 bg-purple-500/5 rounded-full blur-3xl"></div>

      <div class="relative max-w-xl space-y-4">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-i18n="home.connect_title">
          Let's connect
        </h2>
        <p class="text-sm text-muted-foreground leading-relaxed" data-i18n="home.connect_desc">
          Open to mobile development projects, Android consulting, or just talking code.
        </p>
        <div class="flex flex-wrap gap-3 pt-1">
          <Link href={AUTHOR.social.email.href} class={cn(buttonVariants({ size: 'default' }), 'group')}>
            <Icon name="lucide:mail" class="size-4" />
            <span data-i18n="home.send_email">Send email</span>
            <Icon name="lucide:arrow-right" class="size-4 group-hover:translate-x-1 transition-transform" />
          </Link>
          <Link href="/about" class={buttonVariants({ variant: 'outline', size: 'default' })}>
            <span data-i18n="home.view_experience">View experience</span>
          </Link>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(15 23 42 / 0.025)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
  }
  [data-theme='dark'] .bg-grid-pattern {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(241 245 249 / 0.025)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
  }
</style>
