---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
//import Container from '@/components/Container.astro'
//import PhotoCollection from '@/components/PhotoCollection.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllPhotos, getAllTags, getAlbumCount } from '@/lib/data-utils'
import { Image } from 'astro:assets';
import { Camera, Image as ImageIcon, Calendar } from 'lucide-react';
import { 
  Card, 
  CardContent, 
  CardDescription, 
  CardFooter, 
  CardHeader, 
  CardTitle 
} from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"

const photoCollections = await getAllPhotos()
const albumStats = await getAlbumCount()
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="AI & Photo Gallery" description="Curated collection of AI generations and photography." />  
  <Breadcrumbs items={[{ label: 'Gallery', href: '/photos', icon: 'lucide:camera' }]} />

  <div class="mb-12">
    <div class="flex flex-col gap-2 mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-foreground">Galería & Colecciones</h1>
      <p class="text-muted-foreground text-lg">Explora colecciones de fotografía y generaciones de IA.</p>
    </div>

    {/* GRID: grid-auto-rows asegura altura consistente */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
      {photoCollections.map((album) => {
        const imageCount = albumStats[album.id] || 0;
        
        return (
          <a href={`/photos/${album.id}`} class="group block h-full outline-none focus-visible:ring-2 focus-visible:ring-ring rounded-xl">
            {/* CARD */}
            <Card className="flex flex-col h-full overflow-hidden border-border/50 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 bg-card">
              
              {/* --- HEADER IMAGEN --- */}
              <div class="relative aspect-[3/2] overflow-hidden bg-muted">
                <Image 
                  src={album.data.image} 
                  alt={album.data.name}
                  width={700}
                  class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-105"
                />
                
                {/* BADGE */}
                {album.data.model && (
                  <div class="absolute top-3 right-3">
                    <Badge variant="secondary" className="bg-black/60 text-white hover:bg-black/70 backdrop-blur-md border-0 shadow-sm font-medium gap-1.5 px-2.5 py-1">
                      <Camera className="w-3.5 h-3.5 opacity-90" />
                      {album.data.model}
                    </Badge>
                  </div>
                )}
              </div>

              {/* --- WRAPPER DE CONTENIDO --- */}
              {/* Esto ocupa todo el espacio disponible empujando el footer abajo */}
              <div class="flex flex-col flex-1 p-1">
                <CardHeader className="pb-2">
                  <div class="flex justify-between items-start gap-2">
                    <CardTitle className="line-clamp-2 text-xl font-semibold leading-tight group-hover:text-primary transition-colors">
                      {album.data.name}
                    </CardTitle>
                  </div>
                  
                  {album.data.description && (
                    <CardDescription className="line-clamp-2 text-sm leading-relaxed mt-1.5">
                      {album.data.description}
                    </CardDescription>
                  )}
                </CardHeader>

                {/* Contenido (Tags) */}
                <CardContent className="mt-auto pt-0 pb-4">
                  {album.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-2">
                      {album.data.tags.slice(0, 3).map(tag => (
                        <Badge variant="secondary" className="text-[10px] px-2 py-0.5 font-normal bg-secondary/50 text-muted-foreground hover:bg-secondary border-0">
                          #{tag}
                        </Badge>
                      ))}
                      {album.data.tags.length > 3 && (
                        <span class="text-[10px] text-muted-foreground self-center px-1">
                          +{album.data.tags.length - 3}
                        </span>
                      )}
                    </div>
                  )}
                </CardContent>
              </div>

              {/* --- FOOTER SIEMPRE ABAJO --- */}
              <CardFooter className="pt-3 pb-3 border-t border-border/40 bg-muted/20 text-xs text-muted-foreground justify-between">
                 <div class="flex items-center gap-1.5">
                    <Calendar className="w-3.5 h-3.5 opacity-70" />
                    <span class="font-medium">
                        {album.data.date ? album.data.date.toLocaleDateString('es-ES', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A'}
                    </span>
                </div>
                <div class="flex items-center gap-1.5 text-foreground/80">
                    <ImageIcon className="w-3.5 h-3.5 opacity-70" />
                    <span class="font-medium">{imageCount} fotos</span>
                </div>
              </CardFooter>

            </Card>
          </a>
        )
      })}
    </div>
  </div>
</Layout>