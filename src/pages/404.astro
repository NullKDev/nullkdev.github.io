---
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import Layout from '@/layouts/Layout.astro'
import { cn } from '@/lib/utils'
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="404 — Page not found" />

  <section class="flex flex-col items-center justify-center gap-8 py-12 text-center">

    <!-- SVG illustration — minimalist floating astronaut -->
    <div class="w-full max-w-[220px] mx-auto animate-fade-in" style="opacity:0.85">
      <svg viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" aria-hidden="true">

        <!-- Stars -->
        <circle cx="18"  cy="30"  r="1.5" fill="currentColor" opacity="0.25"/>
        <circle cx="172" cy="18"  r="1"   fill="currentColor" opacity="0.2"/>
        <circle cx="185" cy="80"  r="1.5" fill="currentColor" opacity="0.2"/>
        <circle cx="30"  cy="160" r="1"   fill="currentColor" opacity="0.18"/>
        <circle cx="168" cy="178" r="1.5" fill="currentColor" opacity="0.2"/>
        <circle cx="60"  cy="200" r="1"   fill="currentColor" opacity="0.15"/>
        <circle cx="148" cy="205" r="1"   fill="currentColor" opacity="0.15"/>

        <!-- Floating astronaut group -->
        <g>
          <animateTransform attributeName="transform" type="translate"
            values="0,0; 0,-8; 0,0" dur="4s" repeatCount="indefinite"
            calcMode="spline" keySplines="0.45 0 0.55 1; 0.45 0 0.55 1"/>

          <!-- Helmet -->
          <circle cx="100" cy="82" r="32" stroke="currentColor" stroke-width="2" fill="none" opacity="0.9"/>

          <!-- Visor -->
          <path d="M 84 76 Q 100 88 116 76" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.35" stroke-linecap="round"/>
          <ellipse cx="100" cy="79" rx="16" ry="11" fill="currentColor" opacity="0.07"/>

          <!-- Antenna -->
          <line x1="100" y1="50" x2="100" y2="40" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
          <circle cx="100" cy="37" r="3" fill="currentColor" opacity="0.5"/>

          <!-- Body / suit -->
          <rect x="82" y="112" width="36" height="38" rx="10" stroke="currentColor" stroke-width="2" fill="none" opacity="0.9"/>

          <!-- Chest detail -->
          <rect x="91" y="120" width="18" height="10" rx="3" fill="currentColor" opacity="0.1" stroke="currentColor" stroke-width="1" opacity="0.25"/>

          <!-- Left arm -->
          <path d="M 82 122 L 66 138" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
          <circle cx="63" cy="141" r="5" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.6"/>

          <!-- Right arm -->
          <path d="M 118 122 L 134 138" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
          <circle cx="137" cy="141" r="5" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.6"/>

          <!-- Left leg -->
          <path d="M 90 150 L 87 170" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
          <rect x="82" y="170" width="12" height="6" rx="3" fill="currentColor" opacity="0.2" stroke="currentColor" stroke-width="1.5"/>

          <!-- Right leg -->
          <path d="M 110 150 L 113 170" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
          <rect x="106" y="170" width="12" height="6" rx="3" fill="currentColor" opacity="0.2" stroke="currentColor" stroke-width="1.5"/>

          <!-- Shadow / ground reflection (subtle ellipse below) -->
          <ellipse cx="100" cy="195" rx="28" ry="5" fill="currentColor" opacity="0.07">
            <animate attributeName="rx" values="28;22;28" dur="4s" repeatCount="indefinite"
              calcMode="spline" keySplines="0.45 0 0.55 1; 0.45 0 0.55 1"/>
            <animate attributeName="opacity" values="0.07;0.03;0.07" dur="4s" repeatCount="indefinite"
              calcMode="spline" keySplines="0.45 0 0.55 1; 0.45 0 0.55 1"/>
          </ellipse>
        </g>

      </svg>
    </div>

    <!-- Text content -->
    <div class="space-y-3 animate-fade-up">
      <p class="text-xs font-mono font-semibold tracking-widest text-primary uppercase opacity-70">Error 404</p>
      <h1 class="text-3xl font-bold tracking-tight" data-i18n="error.title">Page not found</h1>
      <p class="text-muted-foreground max-w-xs mx-auto text-sm leading-relaxed" data-i18n="error.desc">
        Oops! The page you're looking for doesn't exist.
      </p>
    </div>

    <!-- Actions -->
    <div class="flex flex-wrap gap-3 justify-center animate-fade-up animation-delay-100">
      <Link href="/" class={cn(buttonVariants({ size: 'default' }), 'group shadow-sm shadow-primary/10')}>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span data-i18n="error.go_home">Go to home page</span>
      </Link>
      <Link href="/blog" class={buttonVariants({ variant: 'outline', size: 'default' })}>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        <span data-i18n="error.go_blog">Browse blog</span>
      </Link>
    </div>

  </section>
</Layout>

<style>
  /* The SVG uses currentColor — it inherits foreground automatically in both themes */
</style>
