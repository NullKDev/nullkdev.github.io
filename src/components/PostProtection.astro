---
/**
 * PostProtection wraps article content with optional protection.
 *
 * Modes:
 *   isProtected=false          → render content normally
 *   isProtected=true, password → encrypt at build time, unlock via PasswordProtection React island
 *   isProtected=true, no pw   → static "private" lock screen, no unlock possible
 */
import PasswordProtection from '@/components/PasswordProtection'
import { encryptContent } from '@/lib/encryption'
import { Icon } from 'astro-icon/components'

interface Props {
  isProtected: boolean
  password?: string
  postId: string
  protectionMessage?: string
}

const { isProtected, password, postId, protectionMessage } = Astro.props

let encryptedContent: string | undefined
if (isProtected && password) {
  const html = await Astro.slots.render('default')
  encryptedContent = encryptContent(html, password)
}
---

{!isProtected ? (
  <slot />
) : password && encryptedContent ? (
  <PasswordProtection
    postId={postId}
    encryptedContent={encryptedContent}
    protectionMessage={protectionMessage}
    client:load
  />
) : (
  <!-- Permanently locked — static, no JS -->
  <div class="col-start-2 my-8">
    <!-- Blurred preview strip -->
    <div class="relative mb-6 overflow-hidden rounded-xl border border-border/40">
      <div class="pointer-events-none select-none blur-sm opacity-40 p-6 text-sm leading-relaxed">
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
        <p class="mt-3">Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.</p>
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-background/60 to-background" />
    </div>

    <!-- Static lock card -->
    <div class="flex flex-col items-center text-center gap-5 rounded-2xl border border-border/60 bg-card/60 p-8 shadow-sm">
      <div class="flex items-center justify-center size-14 rounded-2xl bg-muted border border-border/40">
        <Icon name="lucide:lock" class="size-6 text-muted-foreground" />
      </div>
      <div class="space-y-1.5">
        <h3 class="text-lg font-semibold text-foreground">Private Content</h3>
        <p class="text-sm text-muted-foreground max-w-sm leading-relaxed">
          {protectionMessage ?? 'This content is private and not publicly available.'}
        </p>
      </div>
    </div>
  </div>
)}
