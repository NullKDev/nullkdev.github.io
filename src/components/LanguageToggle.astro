---
<button
  id="lang-toggle"
  class="inline-flex items-center justify-center size-8 rounded-md text-xs font-semibold tracking-wide ring-offset-background transition-colors hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 -my-2"
  title="Switch language / Cambiar idioma"
  aria-label="Switch language"
>
  <span id="lang-label">EN</span>
</button>

<script is:inline data-astro-rerun>
  (function () {
    function updateLabel() {
      var lang = localStorage.getItem('lang') || 'en'
      var label = document.getElementById('lang-label')
      if (label) label.textContent = lang.toUpperCase()
    }

    updateLabel()

    var btn = document.getElementById('lang-toggle')
    if (btn) {
      btn.addEventListener('click', function () {
        var current = localStorage.getItem('lang') || 'en'
        var next = current === 'en' ? 'es' : 'en'
        localStorage.setItem('lang', next)

        // Smart redirect on translatable content pages (blog, projects, photos)
        var postLocale = document.querySelector('meta[name="post-locale"]')
        var postSlug = document.querySelector('meta[name="post-slug"]')
        var postSection = document.querySelector('meta[name="post-section"]')
        if (postLocale && postSlug) {
          var slug = postSlug.getAttribute('content')
          var section = postSection ? postSection.getAttribute('content') : 'blog'
          if (next === 'es') {
            var hasEs = document.querySelector('meta[name="post-has-es"]')
            if (hasEs) {
              window.location.href = '/es/' + section + '/' + slug
              return
            }
            // No ES translation: apply i18n in place, no redirect
          } else {
            // Switching back to EN from an ES page
            var hasEn = document.querySelector('meta[name="post-has-en"]')
            if (hasEn) {
              window.location.href = '/' + section + '/' + slug
              return
            }
          }
        }

        document.documentElement.lang = next
        window.dispatchEvent(new CustomEvent('locale-changed', { detail: { locale: next } }))
        if (typeof window.__applyI18n === 'function') window.__applyI18n(next)
        updateLabel()
      })
    }

    window.addEventListener('locale-changed', updateLabel)
  })()
</script>
