---
import { Badge } from '@/components/ui/badge'
import { ContributorAvatar } from '@/components/react/ContributorAvatar'
import { getProjectUrl, parseAuthors } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  project: CollectionEntry<'projects'>
}

const formatDateCompact = (date: Date) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' }).format(date)

const { project } = Astro.props
const locale = project.data.lang === 'es' ? 'es' : 'en'
const projectUrl = getProjectUrl(project.id, locale)
const contributors = await parseAuthors(project.data.contributors ?? [])
const startDate = project.data.startDate ? formatDateCompact(project.data.startDate) : ''
const endDate = project.data.endDate ? formatDateCompact(project.data.endDate) : 'Present'
const dateDisplay = !startDate ? '' : startDate === endDate ? startDate : `${startDate} – ${endDate}`
---

<a
  href={projectUrl}
  data-astro-prefetch="hover"
  class="block group outline-none focus-visible:ring-2 focus-visible:ring-ring rounded-xl h-full"
>
  <article class="flex flex-col h-full overflow-hidden rounded-xl border border-border/50 bg-card hover:border-primary/40 hover:shadow-xl shadow-sm transition-all duration-300">

    <!-- IMAGE / PLACEHOLDER -->
    <div class="relative aspect-[2/1] sm:aspect-[16/9] overflow-hidden shrink-0">
      {project.data.image ? (
        <Image
          src={project.data.image}
          alt={project.data.title}
          width={800}
          height={450}
          format="avif"
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
          transition:name={`project-transition-${project.id}`}
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-primary/15 via-muted/80 to-purple-500/15 flex flex-col items-center justify-center gap-3">
          <div class="p-4 rounded-2xl bg-background/40 backdrop-blur-sm border border-border/40 shadow-inner">
            <Icon name="lucide:git-merge" class="size-10 text-primary/50" />
          </div>
          <span class="text-[10px] font-semibold text-muted-foreground/50 tracking-widest uppercase">
            {project.data.tags?.[0] ?? 'Project'}
          </span>
        </div>
      )}

      <!-- Dim overlay on hover -->
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/8 transition-colors duration-300" />

      <!-- Lock badge -->
      {project.data.protected && (
        <div class="absolute top-3 left-3 flex items-center gap-1.5 px-2 py-1 rounded-lg bg-background/85 backdrop-blur-sm border border-border/40 shadow-sm">
          <Icon name="lucide:lock" class="size-3 text-muted-foreground" />
          <span class="text-[10px] font-medium text-muted-foreground">{project.data.password ? 'Protected' : 'Private'}</span>
        </div>
      )}

      <!-- Status badge -->
      {project.data.status === 'in-development' && (
        <div class={`absolute left-3 ${project.data.protected ? 'top-12' : 'top-3'}`}>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-amber-500/90 text-white text-[10px] font-medium">
            <span class="size-1.5 rounded-full bg-white animate-pulse"></span>
            <span data-i18n="project.status.in_development">In Development</span>
          </span>
        </div>
      )}
      {project.data.status === 'archived' && (
        <div class={`absolute left-3 ${project.data.protected ? 'top-12' : 'top-3'}`}>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-gray-500/90 text-white text-[10px] font-medium">
            <span data-i18n="project.status.archived">Archived</span>
          </span>
        </div>
      )}

      <!-- Open indicator (appears on hover) -->
      <div class="absolute top-3 right-3 translate-y-1 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-200">
        <div class="flex items-center gap-1 px-2 py-1 rounded-lg bg-background/90 backdrop-blur-sm shadow-md border border-border/30">
          <Icon name="lucide:arrow-up-right" class="size-3.5 text-primary" />
          <span class="text-[10px] font-medium text-foreground/80">Open</span>
        </div>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="flex flex-col flex-1 p-4 gap-2.5">

      <!-- Title -->
      <div class="space-y-1">
        <h3 class="text-base font-bold leading-snug text-foreground group-hover:text-primary transition-colors duration-200 line-clamp-2">
          {project.data.title}
        </h3>
        {dateDisplay && (
          <div class="flex items-center gap-1 text-[11px] text-muted-foreground/70">
            <Icon name="lucide:calendar" class="size-3 shrink-0" />
            <span>{dateDisplay}</span>
          </div>
        )}
      </div>

      <!-- Description -->
      <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2 flex-1">
        {project.data.description}
      </p>

      <!-- Footer -->
      <div class="pt-3 mt-auto border-t border-border/30 flex items-center justify-between gap-2">
        <!-- Tags -->
        <div class="flex flex-wrap gap-1.5 min-w-0">
          {(project.data.tags ?? []).slice(0, 3).map((tag: string) => (
            <Badge
              variant="secondary"
              className="px-2 py-0 text-[10px] h-5 font-normal text-muted-foreground bg-secondary/40 border-transparent shrink-0"
            >
              {tag}
            </Badge>
          ))}
          {(project.data.tags ?? []).length > 3 && (
            <span class="text-[10px] text-muted-foreground self-center">
              +{project.data.tags!.length - 3}
            </span>
          )}
        </div>

        <!-- Contributors -->
        {contributors.length > 0 && (
          <div class="flex items-center shrink-0 -space-x-1.5 *:data-[slot=avatar]:ring-2 *:data-[slot=avatar]:ring-background *:data-[slot=avatar]:grayscale">
            {contributors.slice(0, 3).map((c) => (
              <ContributorAvatar
                client:visible
                src={c.avatar}
                alt={c.name}
                fallback={c.name[0]}
                className="size-5"
              />
            ))}
          </div>
        )}
      </div>
    </div>
  </article>
</a>
