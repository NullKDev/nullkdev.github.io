---
import Link from '@/components/Link.astro'
import { Badge } from '@/components/ui/badge'
import { Card } from '@/components/ui/card'
import { ContributorAvatar } from '@/components/react/ContributorAvatar'
import { Separator } from '@/components/ui/separator'
import {
  getCombinedReadingTime,
  getPostUrl,
  getSubpostCount,
  isSubpost,
  parseAuthors,
} from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  entry: CollectionEntry<'blog'>
}

const { entry } = Astro.props
const locale = entry.data.lang === 'es' ? 'es' : 'en'
const postUrl = getPostUrl(entry.id, locale)

const formattedDate = formatDate(entry.data.date)
const readTime = await getCombinedReadingTime(entry.id)
const authors = await parseAuthors(entry.data.authors ?? [])
const subpostCount = !isSubpost(entry.id) ? await getSubpostCount(entry.id) : 0
const hasImage = !!entry.data.image
---

<Link
  href={postUrl}
  class="block group outline-none focus-visible:ring-2 focus-visible:ring-ring rounded-lg mb-3"
>
  <Card className={`flex overflow-hidden border border-border/40 bg-card/50 hover:bg-muted/20 hover:border-border/70 hover:shadow-md transition-all duration-300 shadow-sm ${hasImage ? 'flex-row' : 'flex-col'}`}>

    <!-- THUMBNAIL (solo si tiene imagen) -->
    {hasImage && (
      <div class="relative w-32 sm:w-44 shrink-0 overflow-hidden bg-muted border-r border-border/30">
        <Image
          src={entry.data.image!}
          alt={entry.data.title}
          width={400}
          height={300}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300" />
      </div>
    )}

    <!-- CONTENT -->
    <div class="flex flex-col flex-1 p-4 sm:p-5 gap-2.5 min-w-0">

      <!-- Title + date -->
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-base font-bold tracking-tight text-foreground group-hover:text-primary transition-colors leading-snug line-clamp-2">
          {entry.data.title}
        </h3>
        <Badge
          variant="outline"
          className="flex items-center gap-1 text-[10px] h-5 px-2 py-0 text-muted-foreground shrink-0 mt-0.5 bg-background/50 border-border/60 w-fit"
        >
          <Icon name="lucide:calendar" class="size-3" />
          <span>{formattedDate}</span>
        </Badge>
      </div>

      <!-- Description -->
      <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
        {entry.data.description}
      </p>

      <!-- Footer -->
      <div class="mt-auto pt-2 border-t border-border/30 flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
        <!-- Left: author + stats -->
        <div class="flex items-center gap-3 text-xs text-muted-foreground">
          {authors.length > 0 && (
            <div class="flex items-center gap-1.5">
              <div class="*:data-[slot=avatar]:ring-background flex -space-x-1.5 *:data-[slot=avatar]:ring-2 *:data-[slot=avatar]:grayscale">
                {authors.map((author) => (
                  <ContributorAvatar
                    client:visible
                    src={author.avatar}
                    alt={author.name}
                    fallback={author.name[0]}
                    className="size-5 border-2 border-card"
                  />
                ))}
              </div>
              <span class="font-medium text-foreground/80 hidden sm:inline">
                {authors[0].name}
                {authors.length > 1 && <span class="text-muted-foreground/60"> & {authors.length - 1} others</span>}
              </span>
            </div>
          )}

          {authors.length > 0 && <Separator orientation="vertical" className="h-3.5 hidden sm:block" />}

          <div class="flex items-center gap-1 bg-secondary/30 px-2 py-0.5 rounded-sm">
            <Icon name="lucide:clock" class="size-3 text-primary/70" />
            <span>{readTime}</span>
          </div>

          {subpostCount > 0 && (
            <div class="flex items-center gap-1 text-foreground/70">
              <Icon name="lucide:file-stack" class="size-3" />
              <span>{subpostCount} parts</span>
            </div>
          )}
        </div>

        <!-- Right: tags -->
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 ml-auto">
            {entry.data.tags.slice(0, 3).map((tag) => {
              const isSpecial = tag.toLowerCase() === 'experimental' || tag.toLowerCase() === 'featured'
              return (
                <Badge
                  variant={isSpecial ? 'default' : 'secondary'}
                  className={`px-2 py-0 text-[10px] h-5 font-normal border-transparent ${!isSpecial && 'bg-secondary/40 text-muted-foreground'}`}
                >
                  {tag}
                </Badge>
              )
            })}
            {entry.data.tags.length > 3 && (
              <span class="text-[10px] text-muted-foreground self-center">+{entry.data.tags.length - 3}</span>
            )}
          </div>
        )}
      </div>
    </div>

  </Card>
</Link>
