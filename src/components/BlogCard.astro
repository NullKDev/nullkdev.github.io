---
import Link from '@/components/Link.astro'
import { Badge } from '@/components/ui/badge'
import {
  Card,
  CardHeader,
  CardTitle,
  CardContent,
  CardFooter,
} from "@/components/ui/card"
import { ContributorAvatar } from "@/components/react/ContributorAvatar"
import { Separator } from "@/components/ui/separator"
import {
  getCombinedReadingTime,
  getSubpostCount,
  isSubpost,
  parseAuthors,
} from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import type { CollectionEntry } from 'astro:content'

interface Props {
  entry: CollectionEntry<'blog'>
}

const { entry } = Astro.props

const formattedDate = formatDate(entry.data.date) 
const readTime = await getCombinedReadingTime(entry.id)
const authors = await parseAuthors(entry.data.authors ?? [])
const subpostCount = !isSubpost(entry.id) ? await getSubpostCount(entry.id) : 0
---

<Link
  href={`/${entry.collection}/${entry.id}`}
  class="block group outline-none focus-visible:ring-2 focus-visible:ring-ring rounded-lg mb-4"
>
  <Card className="flex flex-col border border-border/40 bg-card/50 hover:bg-muted/20 hover:border-border transition-all duration-300 shadow-sm hover:shadow-md overflow-hidden">
    
    <div class="flex flex-col p-4 sm:p-5 gap-3">
      
      {/* --- HEADER: Título y Fecha --- */}
      <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2">
        <h3 class="text-lg font-bold tracking-tight text-foreground group-hover:text-primary transition-colors leading-snug">
          {entry.data.title}
        </h3>
        
        {/* Fecha */}
        <Badge 
            variant="outline" 
            className="flex items-center gap-1.5 text-[10px] h-5 px-2 py-0 text-muted-foreground font-medium shrink-0 mt-1 sm:mt-0 bg-background/50 border-border/60 w-fit self-start" 
        >
            <Icon name="lucide:calendar" class="size-3" />
            <span>{formattedDate}</span>
        </Badge>
      </div>

      {/* --- BODY: Descripción --- */}
      <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
        {entry.data.description}
      </p>

      {/* --- FOOTER: Metadata y Tags --- */}
      <div class="mt-1 pt-2 border-t border-border/30 flex flex-wrap items-center justify-between gap-y-2 gap-x-4">
        {/* Lado Izquierdo: Autores y Stats */}
        <div class="flex items-center gap-3 text-xs text-muted-foreground">
            {/* Avatar Stack + Nombre */}
            {authors.length > 0 && (
                <div class="flex items-center gap-2">
                    <div class="*:data-[slot=avatar]:ring-background flex -space-x-2 *:data-[slot=avatar]:ring-2 *:data-[slot=avatar]:grayscale">
                      {authors.map((author) => (
                        <ContributorAvatar 
                          client:visible
                          src={author.avatar}
                          alt={author.name}
                          fallback={author.name[0]}
                          className="size-5 border-2 border-card"
                        />
                      ))}
                    </div>
                    <span class="font-medium text-foreground/80">
                        {authors[0].name}
                        {authors.length > 1 && <span class="text-muted-foreground/60"> & {authors.length - 1} others</span>}
                    </span>
                </div>
            )}

            {/* Separador vertical */}
            {authors.length > 0 && <Separator orientation="vertical" className="h-4 hidden sm:block" />}

            {/* Tiempo de lectura */}
            <div class="flex items-center gap-1.5 bg-secondary/30 px-2 py-0.5 rounded-sm">
                <Icon name="lucide:clock" class="size-3 text-primary/70" />
                <span>{readTime}</span>
            </div>

            {/* Subposts (Si existen) */}
            <div class="flex items-center gap-1.5 text-foreground/70">
                <Icon name="lucide:file-stack" class="size-3" />
                <span>{subpostCount} parts</span>
            </div>
        </div>

        {/* Lado Derecho: Tags*/}
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 ml-auto">
            {entry.data.tags.slice(0, 3).map((tag) => {
              const isSpecial = tag.toLowerCase() === 'experimental' || tag.toLowerCase() === 'featured';
              
              return (
                <Badge 
                    variant={isSpecial ? "default" : "secondary"} 
                    className={`px-2 py-0 text-[10px] h-5 font-normal border-transparent ${!isSpecial && 'bg-secondary/40 text-muted-foreground hover:text-foreground'}`}
                >
                  {tag}
                </Badge>
              )
            })}
            {entry.data.tags.length > 3 && (
                <span class="text-[10px] text-muted-foreground self-center">
                    +{entry.data.tags.length - 3}
                </span>
            )}
          </div>
        )}

      </div>
    </div>
  </Card>
</Link>