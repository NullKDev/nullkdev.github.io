---
/**
 * ProjectProtection wraps project content with terminal-style protection.
 *
 * Modes:
 *   isProtected=false          → render content normally
 *   isProtected=true, password → encrypt at build time, unlock via terminal UI
 *   isProtected=true, no pw   → static "classified" screen, no unlock possible
 */
import ProjectPasswordProtection from '@/components/ProjectPasswordProtection'
import { encryptContentSync } from '@/lib/encryption'

interface Props {
  isProtected: boolean
  password?: string
  postId: string
  protectionMessage?: string
}

const { isProtected, password, postId, protectionMessage } = Astro.props

let encryptedContent: string | undefined
if (isProtected && password) {
  const html = await Astro.slots.render('default')
  encryptedContent = encryptContentSync(html, password)
}
---

{!isProtected ? (
  <slot />
) : password && encryptedContent ? (
  <div class="col-start-2">
    <ProjectPasswordProtection
      postId={postId}
      encryptedContent={encryptedContent}
      protectionMessage={protectionMessage}
      client:load
    />
  </div>
) : (
  <div class="col-start-2 my-8 font-mono text-sm">
    <div class="overflow-hidden rounded-lg border border-zinc-700/60 bg-zinc-950 shadow-2xl">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-zinc-800 bg-zinc-900">
        <div class="flex gap-1.5">
          <span class="size-3 rounded-full bg-red-500/80"></span>
          <span class="size-3 rounded-full bg-yellow-500/80"></span>
          <span class="size-3 rounded-full bg-green-500/80"></span>
        </div>
        <span class="text-xs text-zinc-500 ml-2 tracking-wide">access-control — bash</span>
        <div class="ml-auto px-2 py-0.5 rounded text-[10px] border border-red-500/40 text-red-400/80 uppercase tracking-widest">
          RESTRICTED
        </div>
      </div>
      <div class="p-5 space-y-4">
        <div class="space-y-1 text-zinc-500">
          <p><span class="text-zinc-600">$</span> cat project.md</p>
          <p class="text-red-400/80">permission denied: content is private</p>
        </div>
        <div class="rounded border border-zinc-700/40 bg-zinc-900/60 px-4 py-3 space-y-0.5">
          <p class="text-zinc-300 font-medium">🔒 This project is private</p>
          <p class="text-zinc-500 text-xs">{protectionMessage ?? 'This content is reserved and not publicly accessible.'}</p>
        </div>
      </div>
    </div>
  </div>
)}
